{
  "version": 1,
  "presets": [
    {
      "id": "SpellButton",
      "label": "spellButton",
      "fontFamily": "Fredoka",
      "textAlign": "center",
      "fitMode": "shrinkToFit",
      "textStyle": {
        "fill": "#F7E9CF",
